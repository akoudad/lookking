# Lookking environment variables.
# Copy this file to .env and fill in the values.
# Do NOT commit .env to git.

# Telegram bot token (required) — get from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# LLM API key — provide AT LEAST ONE.
# Priority order in code: Groq -> Gemini -> Cerebras.

# Groq (recommended — free, fast, llama-3.3-70b handles tool calls reliably)
# Get it at: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini (alternative — gemini-2.5-flash)
# Get it at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Cerebras (alternative — very fast but small models struggle with tool-use)
# Get it at: https://cloud.cerebras.ai
CEREBRAS_API_KEY=
